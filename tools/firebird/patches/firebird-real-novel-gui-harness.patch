+void MainWindow::processRealNovelGuiTestLine(const QString &line)
+{
+    if(!qEnvironmentVariableIsSet("FIREBIRD_REAL_NOVEL_GUI_TEST"))
+        return;
+
+    if(line.contains(QStringLiteral(
+            "NMARKDOWN_IT/1 REAL_NOVEL_PROGRESS_START")))
+    {
+        if(!real_novel_gui_test_started)
+        {
+            real_novel_gui_test_started = true;
+            std::puts("FIREBIRD_GUI_TEST/1 START");
+            std::fflush(stdout);
+            QTimer::singleShot(250, this,
+                               &MainWindow::scheduleRealNovelGuiTestSwipe);
+        }
+        return;
     }
+
+    if(line.contains(QStringLiteral(
+            "NMARKDOWN_IT/1 REAL_NOVEL_VISIBLE")))
+    {
+        if(real_novel_gui_test_awaiting_visible != 0)
+        {
+            real_novel_gui_test_awaiting_visible = 0;
+            if(real_novel_gui_test_swipes_sent < 30)
+            {
+                QTimer::singleShot(
+                    250, this,
+                    &MainWindow::scheduleRealNovelGuiTestSwipe);
+            }
+        }
+        return;
+    }
+
+    if(line.contains(QStringLiteral(
+            "NMARKDOWN_IT/1 REAL_NOVEL_30_SWIPE_PASS")))
+    {
+        std::puts("FIREBIRD_GUI_TEST/1 PASS");
+        std::fflush(stdout);
+        // The test owns this process. Avoid Firebird's asynchronous emulator
+        // teardown racing Qt destruction after the final evidence is flushed.
+        QTimer::singleShot(500, []
+        {
+            std::_Exit(EXIT_SUCCESS);
+        });
+    }
 }
 
+void MainWindow::scheduleRealNovelGuiTestSwipe()
+{
+    if(!real_novel_gui_test_started ||
+       real_novel_gui_test_swipes_sent >= 30 ||
+       real_novel_gui_test_awaiting_visible != 0)
+        return;
+
+    QQuickItem *root = ui->keypadWidget->rootObject();
+    QQuickItem *touchpad = root == nullptr
+        ? nullptr
+        : root->findChild<QQuickItem *>(
+              QStringLiteral("firebirdTouchpadMouseArea"));
+    if(touchpad == nullptr || touchpad->width() <= 0 ||
+       touchpad->height() <= 0)
+    {
+        std::puts("FIREBIRD_GUI_TEST/1 FAIL touchpad-object-not-found");
+        std::fflush(stdout);
+        QTimer::singleShot(0, []
+        {
+            std::_Exit(EXIT_FAILURE);
+        });
+        return;
+    }
+
+    const int swipe = ++real_novel_gui_test_swipes_sent;
+    real_novel_gui_test_awaiting_visible = swipe;
+    const QPointF start = touchpad->mapToScene(
+        QPointF(touchpad->width() * 0.5, touchpad->height() * 0.18));
+    const QPointF finish = touchpad->mapToScene(
+        QPointF(touchpad->width() * 0.5, touchpad->height() * 0.82));
+    QQuickWidget *widget = ui->keypadWidget;
+
+    const auto sendMouse = [widget](QEvent::Type type,
+                                    const QPointF &position,
+                                    Qt::MouseButton button,
+                                    Qt::MouseButtons buttons)
+    {
+        const QPoint global = widget->mapToGlobal(position.toPoint());
+        QMouseEvent event(type, position, QPointF(global), button, buttons,
+                          Qt::NoModifier);
+        QCoreApplication::sendEvent(widget, &event);
+    };
+
+    QTimer::singleShot(0, this, [sendMouse, start]
+    {
+        sendMouse(QEvent::MouseButtonPress, start, Qt::LeftButton,
+                  Qt::LeftButton);
+    });
+    constexpr int moveSteps = 8;
+    constexpr int moveIntervalMs = 40;
+    for(int step = 1; step <= moveSteps; ++step)
+    {
+        const qreal fraction =
+            static_cast<qreal>(step) / static_cast<qreal>(moveSteps);
+        const QPointF position =
+            start + (finish - start) * fraction;
+        QTimer::singleShot(step * moveIntervalMs, this,
+                           [sendMouse, position]
+        {
+            sendMouse(QEvent::MouseMove, position, Qt::NoButton,
+                      Qt::LeftButton);
+        });
+    }
+    QTimer::singleShot((moveSteps + 1) * moveIntervalMs, this,
+                       [sendMouse, finish, swipe]
+    {
+        sendMouse(QEvent::MouseButtonRelease, finish, Qt::LeftButton,
+                  Qt::NoButton);
+        std::printf("FIREBIRD_GUI_TEST/1 SWIPE_SENT count=%d\n", swipe);
+        std::fflush(stdout);
+    });
+
+    QTimer::singleShot(20000, this, [this, swipe]
+    {
+        if(real_novel_gui_test_awaiting_visible == swipe)
+        {
+            std::printf(
+                "FIREBIRD_GUI_TEST/1 FAIL visible-timeout swipe=%d\n",
+                swipe);
+            std::fflush(stdout);
+            std::_Exit(EXIT_FAILURE);
+        }
+    });
+}
